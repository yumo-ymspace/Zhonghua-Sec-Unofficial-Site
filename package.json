{
  "name": "zhonghuasec.school",
  "version": "1.0.0",
  "description": "Zhonghua Secondary School unofficial student portal",
  "private": true,
  "scripts": {
    "build:css": "cross-env BROWSERSLIST_IGNORE_OLD_DATA=1 tailwindcss -i src/input.css -o dist/assets/styles.css --minify",
    "build:html": "node scripts/build.js",
    "build": "npm run build:css && npm run build:html",
    "dev": "tailwindcss -i src/input.css -o dist/assets/styles.css --watch"
  },
  "devDependencies": {
    "caniuse-lite": "^1.0.30001799",
    "cross-env": "^10.1.0",
    "tailwindcss": "^3.4.0"
  }
}
